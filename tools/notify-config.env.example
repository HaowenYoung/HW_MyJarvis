# 飞书 Bot configuration
# Used by: tools/notify.sh, tools/feishu-bot.py
#
# Copy to notify-config.env and fill in your own credentials. DO NOT commit notify-config.env.

# 飞书自建应用 credentials
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret

# Webhook (简单推送，不需要 OAuth)
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# 主动发消息的目标用户 open_id
FEISHU_USER_OPEN_ID=your-open-id

# Bot HTTP server port (for event callbacks)
FEISHU_BOT_PORT=9321

# To set up:
# 1. 飞书开放平台 → 创建自建应用 → 获取 App ID + App Secret
# 2. 添加机器人能力 → 获取 webhook URL
# 3. 事件订阅 → 配置回调 URL: http://your-server:9321/feishu/event
# 4. 给 bot 发消息获取你的 open_id
