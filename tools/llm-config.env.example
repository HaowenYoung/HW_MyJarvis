# LLM routing configuration
# Used by: tools/llm-light.sh, tools/llm-local.sh, tools/llm-route.sh
#
# Copy to llm-config.env and fill in your own keys. DO NOT commit llm-config.env.

# SiliconFlow (fast, cheap, for feishu bot + light tasks)
LLM_LIGHT_API_BASE=https://api.siliconflow.cn/v1
LLM_LIGHT_API_KEY=your-siliconflow-api-key-here
LLM_LIGHT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
LLM_LIGHT_TIMEOUT=5

# Local ollama (free, fallback)
LLM_LOCAL_MODEL=qwen3:32b
LLM_LOCAL_TIMEOUT=30
